# Django Production Configuration
# DO NOT include this file in Git; create a .env on the secure live server with these values
DEBUG=False
SECRET_KEY=generate_a_very_long_random_string_here_and_keep_it_secret

# The actual domain name of the backend API (without subpaths)
ALLOWED_HOSTS=api.xtn.com,www.api.xtn.com,127.0.0.1,localhost

# Database Configuration (PostgreSQL)
DB_ENGINE=postgresql
DB_NAME=xtn_db_prod
DB_USER=django_user
DB_PASSWORD=your_secure_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Email Configuration (SMTP)
# Used for sending OTPs and password resets
SMTP_USER=your_official_email@domain.com
SMTP_PASSWORD=app_specific_password_or_smtp_secret
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
FROM_EMAIL=noreply@xtn.com

# Frontend Configuration
# Required to prevent CORS policy blocks from web browsers
FRONTEND_URL=https://xtn.com
